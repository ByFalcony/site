---
import '../styles/main.css';
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Set lang on <html> before render to prevent content flash -->
    <script>try{document.documentElement.dataset.lang=localStorage.getItem('lang')||'en';}catch(e){}</script>
</head>
<body>
    <canvas id="terminal-canvas"></canvas>

    <header>
        <nav>
            <div class="container nav-container">
                <a href="/#home" class="logo">
                    <span class="logo-text">EMIR KILIC</span>
                </a>
                <div class="nav-actions">
                    <ul class="nav-links">
                        <li><a href="/#home" class="nav-link" data-i18n="nav.home">Home</a></li>
                        <li><a href="/#blog" class="nav-link" data-i18n="nav.blog">Learning Log</a></li>
                        <li><a href="/#about" class="nav-link" data-i18n="nav.about">About</a></li>
                        <li><a href="/#contact" class="nav-link" data-i18n="nav.contact">Contact</a></li>
                    </ul>
                    <button class="lang-toggle" id="lang-toggle" aria-label="Toggle Language">
                        <span class="lang-option" data-lang="en">EN</span>
                        <span class="lang-divider">/</span>
                        <span class="lang-option" data-lang="tr">TR</span>
                    </button>
                    <button class="mobile-menu-btn" aria-label="Toggle Menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer class="container" style="padding: 2rem 0; font-size: 0.8rem; color: var(--text-muted); text-align: center; border-top: 1px solid var(--glass-border);">
        <p data-i18n="footer.copy">&copy; 2026 ByFalcon. AI-Friendly Portfolio System.</p>
    </footer>

    <!-- i18n -->
    <script>
      const translations = {
        en: {
          'nav.home': 'Home',
          'nav.blog': 'Learning Log',
          'nav.about': 'About',
          'nav.contact': 'Contact',
          'hero.btn.blog': 'Learning Log',
          'hero.btn.about': 'More About Me',
          'blog.section': 'Learning Log',
          'blog.readmore': 'Read More',
          'contact.section': 'Contact',
          'contact.view': 'View Profile →',
          'footer.copy': '© 2026 ByFalcon. AI-Friendly Portfolio System.',
          'post.back': '← Back to Learning Log',
          'post.backbtn': 'Back to List',
        },
        tr: {
          'nav.home': 'Ana Sayfa',
          'nav.blog': 'Öğrenme Günlüğü',
          'nav.about': 'Hakkımda',
          'nav.contact': 'İletişim',
          'hero.btn.blog': 'Öğrenme Günlüğü',
          'hero.btn.about': 'Hakkımda',
          'blog.section': 'Öğrenme Günlüğü',
          'blog.readmore': 'Devamını Oku',
          'contact.section': 'İletişim',
          'contact.view': 'Profili Görüntüle →',
          'footer.copy': '© 2026 ByFalcon. Yapay Zeka Dostu Portfolyo Sistemi.',
          'post.back': '← Öğrenme Günlüğüne Dön',
          'post.backbtn': 'Listeye Dön',
        }
      };

      function applyLang(lang) {
        document.querySelectorAll('[data-i18n]').forEach(el => {
          const key = el.getAttribute('data-i18n');
          const t = translations[lang];
          if (t && t[key]) el.textContent = t[key];
        });

        document.querySelectorAll('[data-en]').forEach(el => {
          const text = el.getAttribute('data-' + lang);
          if (text) el.textContent = text;
        });

        document.querySelectorAll('.lang-option').forEach(opt => {
          opt.classList.toggle('active', opt.getAttribute('data-lang') === lang);
        });

        document.documentElement.lang = lang;
        document.documentElement.dataset.lang = lang;
        localStorage.setItem('lang', lang);
      }

      function initLang() {
        const saved = localStorage.getItem('lang') || 'en';
        applyLang(saved);

        const toggle = document.getElementById('lang-toggle');
        if (toggle) {
          toggle.addEventListener('click', () => {
            const current = localStorage.getItem('lang') || 'en';
            applyLang(current === 'en' ? 'tr' : 'en');
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLang);
      } else {
        initLang();
      }
    </script>

    <!-- Nav -->
    <script>
      function initMobileMenu() {
        const mobileBtn = document.querySelector('.mobile-menu-btn');
        const navLinks = document.querySelector('.nav-links');

        if (mobileBtn && navLinks) {
          mobileBtn.addEventListener('click', () => {
            mobileBtn.classList.toggle('active');
            navLinks.classList.toggle('active');
          });

          document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', () => {
              mobileBtn.classList.remove('active');
              navLinks.classList.remove('active');
            });
          });
        }
      }

      function setupNav() {
        const nav = document.querySelector('nav');
        if (!nav) return;
        window.addEventListener('scroll', () => {
          if (window.scrollY > 50) {
            nav.style.padding = '0.5rem 0';
            nav.style.background = 'rgba(10, 10, 10, 0.95)';
          } else {
            nav.style.padding = '1rem 0';
            nav.style.background = 'rgba(10, 10, 10, 0.8)';
          }
        });

        document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
          anchor.addEventListener('click', function (e) {
            if(window.location.pathname !== '/') return;
            e.preventDefault();
            const targetId = this.getAttribute('href').replace('/', '');
            const target = document.querySelector(targetId);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth' });
            }
          });
        });
      }

      initMobileMenu();
      setupNav();
    </script>

    <!-- Terminal Animation -->
    <script>
      import { initTerminalEffect } from '../terminal.js';
      document.addEventListener('DOMContentLoaded', () => {
        initTerminalEffect('terminal-canvas');
      });
      if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initTerminalEffect('terminal-canvas');
      }
    </script>
</body>
</html>
